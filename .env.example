# =========================
# Database
# =========================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hyacine_gallery

# =========================
# Redis
# =========================
REDIS_URL=redis://localhost:6379/0

# =========================
# Storage
# =========================
# local or s3
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# =========================
# Admin Panel
# =========================
ADMIN_PANEL_SLUG=change-me-to-random-string
ADMIN_TOKEN=change-me-to-a-secure-token

# =========================
# Backend
# =========================
BACKEND_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
DEBUG=false

# =========================
# Telegram Bot
# =========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL=
TELEGRAM_COMMENT_GROUP=
TELEGRAM_ADMIN_CHATS=[]

# =========================
# Platform Credentials
# =========================
PIXIV_PHPSESSID=
PIXIV_DEVICE_TOKEN=
BILIBILI_COOKIE=
