# =========================
# 数据库
# =========================
# 开发环境默认使用 SQLite，生产环境切换为 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./hyacine_gallery.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hyacine_gallery

# =========================
# Redis
# =========================
REDIS_URL=redis://localhost:6379/0

# =========================
# 存储
# =========================
# local 或 s3
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# =========================
# 管理面板
# =========================
# slug 是管理面板的 URL 路径，请改为随机字符串以防止被猜到
ADMIN_PANEL_SLUG=change-me-to-random-string
# 管理 API 的认证令牌，前端管理面板和 Bot 均使用此令牌
ADMIN_TOKEN=change-me-to-a-secure-token

# =========================
# 后端
# =========================
BACKEND_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
DEBUG=false

# =========================
# 前端
# =========================
NEXT_PUBLIC_API_URL=http://localhost:8000

# =========================
# Telegram Bot
# =========================
TELEGRAM_BOT_TOKEN=
# 频道 ID，例如 @my_channel 或 -1001234567890
TELEGRAM_CHANNEL=
# 评论群组 ID（可选）
TELEGRAM_COMMENT_GROUP=
# 管理员 Telegram 用户 ID 列表，JSON 数组格式
TELEGRAM_ADMIN_CHATS=[]

# =========================
# 平台凭据（爬虫可选）
# =========================
PIXIV_PHPSESSID=
PIXIV_DEVICE_TOKEN=
BILIBILI_COOKIE=
