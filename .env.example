# =========================
# 数据库
# =========================
# 开发环境默认使用 SQLite；生产/Docker 推荐指向外部 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./hyacine_gallery.db
# DATABASE_URL=postgresql+asyncpg://user:password@db.example.com:5432/hyacine_gallery

# =========================
# 存储
# =========================
# local 或 s3
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# =========================
# 管理面板
# =========================
# slug 是管理面板的 URL 路径，请改为随机字符串以防止被猜到
ADMIN_PANEL_SLUG=change-me-to-random-string
# 管理 API 的认证令牌，Bot 使用此令牌调用后端（前端已改为 TG OAuth）
ADMIN_TOKEN=change-me-to-a-secure-token

# =========================
# Telegram OAuth（管理面板登录）
# =========================
# 用于验证 Login Widget HMAC 签名（与 TELEGRAM_BOT_TOKEN 相同）
TELEGRAM_BOT_USERNAME=your_bot_username_without_at
# JWT 签名密钥，请生成随机字符串
JWT_SECRET=change-me-to-a-secure-jwt-secret
# JWT 有效期（小时），默认 720 = 30 天
# JWT_EXPIRE_HOURS=720

# =========================
# 后端
# =========================
BACKEND_URL=http://localhost:8000
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
DEBUG=false

# =========================
# 前端
# =========================
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3000
# 前端服务端渲染访问后端的内部地址；Docker Compose 中默认使用 http://backend:8000
# SERVER_API_URL=http://localhost:8000
GALLERY_URL=http://localhost:3000

# =========================
# Telegram Bot
# =========================
TELEGRAM_BOT_TOKEN=
# 频道 ID，例如 @my_channel 或 -1001234567890
TELEGRAM_CHANNEL=
# 评论群组 ID（可选）
TELEGRAM_COMMENT_GROUP=
# 管理员 Telegram 用户 ID 列表，JSON 数组格式
TELEGRAM_ADMIN_CHATS=[]

# =========================
# 平台凭据（爬虫可选）
# =========================
PIXIV_PHPSESSID=
PIXIV_DEVICE_TOKEN=
BILIBILI_COOKIE=
