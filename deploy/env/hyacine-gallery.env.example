# Hyacine Gallery shared deployment environment.
# Copy to /etc/hyacine-gallery/hyacine-gallery.env for systemd, or to .env for Docker.

# Database. Production should point at an external PostgreSQL service.
DATABASE_URL=postgresql+asyncpg://user:password@db.example.com:5432/hyacine_gallery

# Backend public URL. Used for generated image URLs and service-to-service defaults.
BACKEND_URL=http://localhost:8000
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS='["http://localhost:3000"]'
LOG_LEVEL=INFO

# Storage. For native systemd deployments, keep local data outside the app tree.
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/var/lib/hyacine-gallery/uploads
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_REGION=
# S3_PUBLIC_URL=

# Admin panel and auth.
ADMIN_PANEL_SLUG=change-me-to-random-string
ADMIN_TOKEN=change-me-to-a-secure-token
TELEGRAM_BOT_USERNAME=your_bot_username_without_at
JWT_SECRET=change-me-to-a-secure-jwt-secret
JWT_EXPIRE_HOURS=720
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME="Hyacine Gallery"
WEBAUTHN_ORIGIN=http://localhost:3000

# Frontend. NEXT_PUBLIC_API_URL is read at frontend build time.
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000
# Server-side API URL for Next.js SSR. Usually same as BACKEND_URL for systemd,
# and http://backend:8000 inside Docker Compose.
SERVER_API_URL=http://localhost:8000
GALLERY_URL=http://localhost:3000

# Telegram bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL=
TELEGRAM_COMMENT_GROUP=
TELEGRAM_ADMIN_CHATS='[]'

# Optional crawler credentials.
PIXIV_PHPSESSID=
PIXIV_DEVICE_TOKEN=
BILIBILI_COOKIE=

# Optional AI features.
AI_LLM_ENABLED=false
AI_LLM_BASE_URL=
AI_LLM_API_KEY=
AI_LLM_MODEL=gpt-4o-mini
AI_EMBEDDING_ENABLED=false
AI_EMBEDDING_PROVIDER=local
AI_EMBEDDING_BASE_URL=
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=BAAI/bge-m3
AI_EMBEDDING_DIMENSION=1024
SAUCENAO_API_KEY=
AI_AUTO_TAG_ON_IMPORT=false
AI_AUTO_TAG_CONFIDENCE=0.8
NSFW_DETECTION_ENABLED=false
NSFW_DETECTION_PROVIDER=llm
NSFW_THRESHOLD=0.7
